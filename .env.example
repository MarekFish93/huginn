# PostgreSQL — any provider works (Supabase, Neon, Railway, self-hosted)
DATABASE_URL=postgresql://user:password@localhost:5432/tgdesk

# Redis — required for real-time Telegram → browser bridging
REDIS_URL=redis://localhost:6379

# Anthropic — get your key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot — create one via @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-...
# Your personal chat ID or a group ID — use @userinfobot to find it
TELEGRAM_CHAT_ID=123456789
# A random secret to validate incoming webhooks (generate with: openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=your-random-secret-here

# Public URL of your deployment (no trailing slash) — needed to register the webhook
NEXT_PUBLIC_APP_URL=https://your-domain.com
